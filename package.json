{
  "name": "openclaw-sessions-analyse",
  "version": "0.1.0",
  "description": "Local HTTP viewer for OpenClaw agent sessions (osa CLI)",
  "type": "module",
  "bin": {
    "osa": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
